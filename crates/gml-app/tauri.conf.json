{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaleShift",
  "version": "0.1.0",
  "identifier": "io.github.igrini.taleshift",
  "build": {
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "TaleShift — Your world remembers.",
    "longDescription": "TaleShift is a local-first AI game master for persistent solo RPG worlds where characters, choices, and consequences are remembered."
  }
}
