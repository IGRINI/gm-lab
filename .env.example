# TaleShift configuration example. All values are optional.
# setup.ps1 writes only its own managed, non-secret block to .env.
# Never commit API keys, OAuth credentials, or Hugging Face tokens.

# LLM connector
# GM_BACKEND=mock
# GM_MODEL=
# GM_API_BASE=https://api.example.com/v1
# GM_API_KEY=

# Local inference. setup.ps1 fills these according to the selected profile.
# The legacy gm-lab directory name is kept for compatibility.
# GM_INFERENCE_HOME=C:/Users/you/AppData/Local/gm-lab/inference
# GM_RAG_ENABLED=true
# GM_RAG_RERANK_ENABLED=true
# GM_STT_ENABLED=false
# GM_TTS_ENABLED=false
# GM_IMAGE_ENABLED=true
# GM_IMAGE_PROVIDER=grok
# USE_FLASH=auto

# Managed setup supplies verified local model paths automatically. The next
# overrides are only for a custom, fully preinstalled runtime. Use local folders,
# not Hugging Face repo IDs: runtime downloads are disabled by default.
# GM_RAG_EMBEDDINGS_MODEL=D:/models/embedder
# GM_RAG_RERANK_MODEL=D:/models/reranker
# GM_STT_MODEL=D:/models/whisper-small
# STT_MAX_BYTES=33554432
# STT_MAX_SECONDS=600
# GM_TTS_URL=http://127.0.0.1:8077
# GM_TTS_READY_TIMEOUT=300
# GM_TTS_SPAWN_CMD=
# GM_TTS_SPAWN_DIR=
# The next three flags are only for a manually managed custom runtime. setup.ps1
# derives them from verified install markers automatically.
# GM_LOCAL_STT_AVAILABLE=true
# GM_LOCAL_TTS_AVAILABLE=true
# GM_LOCAL_IMAGE_AVAILABLE=true
# GMLAB_ALLOW_RUNTIME_DOWNLOADS=0
# IMAGE_COMFY_PORT=8188
# GM_IMAGE_TIMEOUT_SECONDS=300

# Server mode is loopback-only. External GM_HOST values are rejected; point an
# authenticated reverse proxy at the loopback listener when remote access is required.
# GM_HOST=127.0.0.1
# GM_PORT=8000
# GM_HTTPS=false
# GM_HTTPS_PORT=8443
# GM_OPEN_BROWSER=true

# Optional data-path overrides. Defaults use the per-user application folder.
# GM_SETTINGS_PATH=
# GM_DIALOG_DB=
# GM_RAG_CACHE_PATH=
# GM_RAG_WORLDS_DIR=
# GM_PACKAGES_DIR=
# GM_TTS_CACHE_DIR=

# Output behavior
# GM_RESPONSE_LANGUAGE=en
# GM_STREAM_GM_CONTENT=true
# GM_PARALLEL_TOOL_CALLS=true
# GM_TTS_AUTOPLAY=false
